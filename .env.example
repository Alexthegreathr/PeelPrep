# PeelPrep environment template — copy to .env.local and fill in real values.
# Never commit real credentials. See docs/ARCHITECTURE.md §6 for details.

# ── Supabase (Phase 2+) ────────────────────────────────────────────────
# Local dev values come from `supabase start` output.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Bypasses RLS — used exclusively in src/lib/supabase/admin.ts.
SUPABASE_SERVICE_ROLE_KEY=

# ── AI providers (Phase 5+) ────────────────────────────────────────────
# "mock" (default for dev/tests/demo) or "anthropic".
AI_PROVIDER=mock
# Server-only. Required only when AI_PROVIDER=anthropic.
ANTHROPIC_API_KEY=
# Default model for all tasks (ratified decision #1).
AI_MODEL_DEFAULT=claude-opus-4-8

# ── Stripe (Phase 10+) ─────────────────────────────────────────────────
# Server-only.
STRIPE_SECRET_KEY=
# Server-only. From `stripe listen` locally, or the dashboard webhook config.
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Price ids mapped to plan keys (see docs/DATABASE.md §2 plans).
STRIPE_PRICE_PLUS_MONTHLY=
STRIPE_PRICE_PRO_MONTHLY=

# ── App ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Set to 1 to show the "demo / fictional data" banner (Phase 12).
NEXT_PUBLIC_DEMO_MODE=
