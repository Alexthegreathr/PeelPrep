# PeelPrep environment template — copy to .env.local and fill in real values.
# Never commit real credentials. See docs/ARCHITECTURE.md §6 for details.

# ── Supabase (REQUIRED from Phase 2) ───────────────────────────────────
# Local dev values are printed by `supabase start` (API URL + anon/service keys).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Bypasses RLS — used exclusively in src/lib/supabase/admin.ts.
SUPABASE_SERVICE_ROLE_KEY=

# ── Security (Phase 2+) ────────────────────────────────────────────────
# Optional salt for hashing IPs/emails in rate-limit keys. If unset, the
# service-role key is used as the salt fallback. Set a dedicated random value
# in production (e.g. `openssl rand -hex 16`).
RATE_LIMIT_SALT=

# Set only to run the opt-in Supabase integration tests (src/test/integration).
# Requires a running local stack with migration 001 applied. Leave unset for
# the normal `npm test` run.
SUPABASE_INTEGRATION=

# ── AI providers (Phase 5+) ────────────────────────────────────────────
# "mock" (default for dev/tests/demo) or "anthropic".
AI_PROVIDER=mock
# Server-only. Required only when AI_PROVIDER=anthropic.
ANTHROPIC_API_KEY=
# Default model for all tasks (ratified decision #1).
AI_MODEL_DEFAULT=claude-opus-4-8
# Research provider: "manual" (user-provided only) or "mock" (fictional demo
# sources). Defaults to mock in demo/mock-AI mode, otherwise manual. No live
# web research or scraping in the beta.
RESEARCH_PROVIDER=

# ── Stripe (Phase 10+) ─────────────────────────────────────────────────
# Server-only.
STRIPE_SECRET_KEY=
# Server-only. From `stripe listen` locally, or the dashboard webhook config.
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Price ids mapped to plan keys (see docs/DATABASE.md §2 plans).
STRIPE_PRICE_PLUS_MONTHLY=
STRIPE_PRICE_PRO_MONTHLY=

# ── App ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Set to 1 to show the "demo / fictional data" banner (Phase 12).
NEXT_PUBLIC_DEMO_MODE=
